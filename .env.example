S3_REGION="auto"
S3_BUCKET="trustlayer-documents"
S3_ACCESS_KEY_ID="replace-with-r2-access-key-id"
S3_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
S3_PUBLIC_BASE_URL=""
