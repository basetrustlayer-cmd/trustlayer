DATABASE_URL="postgresql://trustlayer:trustlayer@localhost:5432/trustlayer_dev?schema=public"
REDIS_URL="redis://localhost:6379"
AUTH_SECRET="replace-with-a-random-64-character-secret"
NODE_ENV="development"

STORAGE_PROVIDER="r2"
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="trustlayer-documents"
S3_ACCESS_KEY_ID="replace-with-r2-access-key-id"
S3_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
S3_PUBLIC_BASE_URL=""

API_GATEWAY_URL="http://localhost:3000"

STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_SUCCESS_URL="http://localhost:3001/billing?success=1"
STRIPE_CANCEL_URL="http://localhost:3001/billing?canceled=1"

# Cron jobs
CRON_SECRET=change-me-to-a-long-random-cron-secret
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Email notifications
EMAIL_PROVIDER="audit"
EMAIL_FROM="TrustLayer <notifications@trustlayer.io>"
RESEND_API_KEY="re_replace_me"
