generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum UserRole {
  ADMIN
  INTEGRATOR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  ONE_TIME
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
  MANUAL
}

enum ApiKeyEnvironment {
  TEST
  LIVE
}

enum PlanTier {
  SANDBOX
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubjectType {
  INDIVIDUAL
  BUSINESS
}

enum VerificationMethod {
  PHONE_OTP
  GHANA_CARD
  BVN
  NIN
  BUSINESS_ORC
}

enum IdentityVerificationStatus {
  OTP_SENT
  VERIFIED
  FAILED
  EXPIRED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  verificationRequests VerificationRequest[]
  auditLogs            AuditLog[]
  platforms            Platform[]
  subscription         Subscription?
  invoices             Invoice[]
  payments             Payment[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(INTEGRATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  sessions    Session[]
  auditLogs   AuditLog[]
  platforms   Platform[]
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(MEMBER)
  organizationId String
  userId         String
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model VerificationRequest {
  id             String             @id @default(cuid())
  organizationId String
  title          String
  status         VerificationStatus @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    VerificationDocument[]
}

model VerificationDocument {
  id                    String   @id @default(cuid())
  verificationRequestId String
  uploadedById          String?
  filename              String
  contentType           String
  sizeBytes             Int
  storageKey            String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)

  @@index([verificationRequestId])
  @@index([uploadedById])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  notes          String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model SubscriptionPlan {
  id                 String          @id @default(cuid())
  name               String
  slug               String          @unique
  description        String?
  priceCents         Int
  currency           String          @default("USD")
  interval           BillingInterval
  trialDays          Int?
  isActive           Boolean         @default(true)
  maxOrganizations   Int?
  maxDocuments       Int?
  includesTrustScore Boolean         @default(false)
  includesBadge      Boolean         @default(false)
  includesApiAccess  Boolean         @default(false)
  externalProductId  String?
  externalPriceId    String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  provider               PaymentProvider    @default(PAYSTACK)
  externalCustomerId     String?
  externalSubscriptionId String?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices     Invoice[]

  @@index([status])
}

model Invoice {
  id                String        @id @default(cuid())
  subscriptionId    String
  organizationId    String
  invoiceNumber     String        @unique
  status            InvoiceStatus @default(DRAFT)
  subtotalCents     Int
  taxCents          Int           @default(0)
  totalCents        Int
  currency          String        @default("USD")
  externalInvoiceId String?
  hostedInvoiceUrl  String?
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([organizationId])
}

model Payment {
  id                String          @id @default(cuid())
  invoiceId         String
  organizationId    String
  provider          PaymentProvider
  externalPaymentId String?
  reference         String?         @unique
  amountCents       Int
  currency          String          @default("USD")
  status            PaymentStatus   @default(PENDING)
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model Platform {
  id             String            @id @default(cuid())
  organizationId String?
  userId         String
  name           String
  slug           String            @unique
  description    String?
  website        String?
  contactEmail String?
  environment    ApiKeyEnvironment @default(TEST)
  planTier       PlanTier          @default(SANDBOX)
  apiScopes     Json?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys       ApiKey[]
  webhooks      Webhook[]
}

model Subject {
  id          String      @id
  type        SubjectType
  externalId  String
  country     String      @default("GH")
  verificationTier String   @default("UNVERIFIED")
  tierUpdatedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  verifications VerificationSession[]
  trustScores   TrustScore[]
  scoreHistory  ScoreHistory[]

  @@index([externalId])
}

model VerificationSession {
  id               String                     @id @default(cuid())
  subjectId        String
  method           VerificationMethod
  status           IdentityVerificationStatus
  registryResponse Json?
  tierBefore       String?
  tierAfter        String?
  expiresAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId, createdAt])
}


model ApiKey {
  id          String            @id @default(cuid())
  platformId  String
  keyPrefix   String
  keyHash     String            @unique
  scopes      Json
  environment ApiKeyEnvironment @default(TEST)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
  @@index([keyPrefix])
  @@index([revokedAt])
}


model Webhook {
  id          String   @id @default(cuid())
  platformId  String
  url         String
  events      Json
  secretHash  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platform   Platform          @relation(fields: [platformId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([platformId])
  @@index([isActive])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhookId     String
  eventType     String
  status        String
  responseCode  Int?
  attemptCount  Int       @default(0)
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([eventType])
  @@index([status])
}


model TrustScore {
  id                 String   @id @default(cuid())
  subjectId          String
  role               String
  score              Int      @default(0)
  tierCeiling        Int      @default(30)
  confidence         Float    @default(0.1)
  factorIdentity     Int      @default(0)
  factorTransactions Int      @default(0)
  factorReviews      Int      @default(0)
  factorDisputes     Int      @default(0)
  factorRoleSpecific Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  history ScoreHistory[]

  @@unique([subjectId, role])
  @@index([subjectId])
}

model ScoreHistory {
  id           String   @id @default(cuid())
  trustScoreId String
  subjectId    String
  role         String
  score        Int
  tierCeiling  Int
  confidence   Float
  factors      Json?
  reason       String?
  createdAt    DateTime @default(now())

  trustScore TrustScore @relation(fields: [trustScoreId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId, role, createdAt])
}


model Transaction {
  id              String   @id @default(cuid())
  sellerSubjectId String
  buyerSubjectId  String
  sellerRole      String   @default("seller")
  buyerRole       String   @default("buyer")
  amountCents     Int
  currency        String   @default("GHS")
  status          String   @default("COMPLETED")
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sellerSubjectId])
  @@index([buyerSubjectId])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id                String   @id @default(cuid())
  reviewerSubjectId String
  revieweeSubjectId String
  reviewerRole      String
  revieweeRole      String
  rating            Int
  comment           String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([reviewerSubjectId])
  @@index([revieweeSubjectId])
  @@index([rating])
  @@index([createdAt])
}

model Dispute {
  id                  String   @id @default(cuid())
  filerSubjectId      String
  respondentSubjectId String
  filerRole           String
  respondentRole      String
  status              String   @default("OPEN")
  faultParty          String?
  reason              String?
  resolution          String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([filerSubjectId])
  @@index([respondentSubjectId])
  @@index([status])
  @@index([faultParty])
  @@index([createdAt])
}
